{
  "agents": {
    "defaults": {
      "model": {
        "primary": "groq/openai/gpt-oss-120b",
        "fallbacks": ["groq/qwen/qwen3-32b"]
      },
      "models": {
        "groq/openai/gpt-oss-120b": { "alias": "GPT-OSS" },
        "groq/qwen/qwen3-32b": { "alias": "Qwen3" },
        "groq/moonshotai/kimi-k2-instruct-0905": { "alias": "KimiK2" },
        "xai/grok-3-fast": { "alias": "Grok" }
      },
      "workspace": "/home/node/.openclaw/workspace"
    }
  },

  "models": {
    "providers": {
      "groq": {
        "baseUrl": "https://api.groq.com/openai/v1",
        "apiKey": "${GROQ_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "openai/gpt-oss-120b",
            "name": "groq/openai/gpt-oss-120b"
          },
          {
            "id": "qwen/qwen3-32b",
            "name": "groq/qwen/qwen3-32b"
          },
          {
            "id": "moonshotai/kimi-k2-instruct-0905",
            "name": "groq/moonshotai/kimi-k2-instruct-0905"
          }
        ]
      },
      "xai": {
        "baseUrl": "https://api.x.ai/v1",
        "apiKey": "${XAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "grok-3-fast",
            "name": "xai/grok-3-fast"
          }
        ]
      }
    }
  },

  "gateway": {
    "port": 18789,
    "bind": "lan",
    "trustedProxies": ["172.16.0.0/12", "10.0.0.0/8"],
    "controlUi": {
      "allowedOrigins": ["https://claw.openleg.ch"]
    },
    "auth": {
      "mode": "password",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "password": "${OPENCLAW_GATEWAY_PASSWORD}"
    }
  },

  "tools": {
    "profile": "full"
  },

  "session": {
    "dmScope": "per-channel-peer",
    "reset": { "mode": "daily", "atHour": 4 }
  },

  "cron": {
    "enabled": true
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "allowlist",
      "streaming": "off"
    }
  }
}
