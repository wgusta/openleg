# OpenLEG Environment Variables
# Copy this file to .env and fill in your values

# === PostgreSQL ===
POSTGRES_PASSWORD=your-secure-postgres-password

# === Application Settings ===
APP_BASE_URL=https://openleg.ch
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,openleg.ch
# DATABASE_URL is set automatically in docker-compose.yml

# === Email (SMTP) ===
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=hallo@openleg.ch
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=hallo@openleg.ch
ADMIN_EMAIL=hallo@openleg.ch

# === Analytics ===
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# === Demo Provisioning (staging) ===
DEMO_MODE=false
DEMO_SUBDOMAIN=newbaden
DEMO_ENV=staging
DEMO_BFS_NUMBER=79999

# === Admin Access ===
ADMIN_TOKEN=your-secure-admin-token

# === Session Settings ===
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# === Cron/Webhook Secrets ===
CRON_SECRET=your-cron-secret
DEEPSIGN_WEBHOOK_SECRET=your-deepsign-webhook-secret

# === OpenClaw (VPS only) ===
ANTHROPIC_API_KEY=sk-ant-...
OPENCLAW_GATEWAY_TOKEN=<generate-secure-token>
BRAVE_API_KEY=<brave-api-key>
OPENCLAW_READONLY=false

# === Telegram (LEA notifications) ===
TELEGRAM_BOT_TOKEN=<bot-token-from-botfather>
TELEGRAM_CHAT_ID=<chat-id-from-getUpdates>
TELEGRAM_WEBHOOK_SECRET=<random-secret-for-webhook-verification>

# === AgentMail (API-first email) ===
AGENTMAIL_API_KEY=
AGENTMAIL_DOMAIN=mail.openleg.ch
AGENTMAIL_LEA_INBOX=lea@mail.openleg.ch
AGENTMAIL_WEBHOOK_SECRET=

# === Internal Auth (LEA -> Flask) ===
INTERNAL_TOKEN=<generate-secure-token>
